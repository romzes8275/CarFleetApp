<Window x:Class="CarFleetApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fleet Management Dashboard" 
        Height="800" Width="1200"
        UseLayoutRounding="True" 
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        MinWidth="1050" MinHeight="700" 
        WindowStartupLocation="CenterScreen" 
        Background="#F4F7FE">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Статистика -->
            <RowDefinition Height="Auto"/>
            <!-- Таби -->
            <RowDefinition Height="Auto"/>
            <!-- Фільтри -->
            <RowDefinition Height="*"/>
            <!-- Список карток -->
        </Grid.RowDefinitions>

        <!-- 1. ВЕРХНІ КАРТКИ СТАТИСТИКИ -->
        <UniformGrid Rows="1" Columns="4" Margin="0,0,0,25">
            <!-- Загальний заробіток -->
            <Border Background="White" CornerRadius="20" Margin="10,0" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="ЗАГАЛЬНИЙ ЗАРОБІТОК" FontSize="11" Foreground="#A3AED0" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock x:Name="txtTotalIncome" Text="7 100" FontSize="28" FontWeight="Bold"  Foreground="#2B3674" RenderOptions.ClearTypeHint="Enabled"/>
                        <TextBlock Text=" UAH" FontSize="18" VerticalAlignment="Bottom" Margin="5,0,0,4" Foreground="#2B3674"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Поточні витрати -->
            <Border Background="White" CornerRadius="20" Margin="10,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="ПОТОЧНІ ВИТРАТИ" FontSize="11" Foreground="#A3AED0" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock x:Name="txtTotalExpenses" Text="3 540" FontSize="28" FontWeight="Bold" Foreground="#2B3674"/>
                        <TextBlock Text=" UAH" FontSize="18" VerticalAlignment="Bottom" Margin="5,0,0,4" Foreground="#2B3674"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Чистий прибуток -->
            <Border Background="#4318FF" CornerRadius="20" Margin="10,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="ЧИСТИЙ ПРИБУТОК" FontSize="11" Foreground="#E9EDF7" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8">
                        <TextBlock x:Name="txtTotalProfit" Text="3 560" FontSize="28" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text=" UAH" FontSize="18" VerticalAlignment="Bottom" Margin="5,0,0,4" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Статус БД -->
            <Border Background="White" CornerRadius="20" Margin="10,0" Padding="20">
                <StackPanel>
                    <TextBlock Text="СТАТУС СХОВИЩА (DB)" FontSize="11" Foreground="#A3AED0" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12">
                        <Ellipse Width="8" Height="8" Fill="#4318FF" Margin="0,0,8,0"/>
                        <TextBlock Text="SQLite Connected" FontSize="14" FontWeight="Bold" Foreground="#2B3674"/>
                    </StackPanel>
                    <Border Background="#F4F7FE" CornerRadius="5" HorizontalAlignment="Left" Padding="8,3">
                        <TextBlock Text="C# COMPATIBLE" FontSize="10" FontWeight="Bold" Foreground="#4318FF"/>
                    </Border>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- 2. НАВІГАЦІЯ (ТАБИ) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,10,20">
            <Button Content="Флот автомобілів (3)" Background="Transparent" BorderThickness="0,0,0,3" BorderBrush="#4318FF" Foreground="#4318FF" FontWeight="Bold" Padding="10,5" Margin="0,0,20,0"/>
            <Button Content="Реєстр водіїв (2)" Background="Transparent" BorderThickness="0" Foreground="#A3AED0" FontWeight="Bold" Padding="10,5" Margin="0,0,20,0"/>
            <Button Content="Історія поїздок (2)" Background="Transparent" BorderThickness="0" Foreground="#A3AED0" FontWeight="Bold" Padding="10,5"/>
        </StackPanel>

        <!-- 3. ФІЛЬТРИ ТА ПОШУК -->
        <Border Grid.Row="2" Background="White" CornerRadius="18" Padding="15" Margin="10,0,10,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <!-- Пошук -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Класи ТЗ -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Чекбокс -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Сортування -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Кнопка Додати -->
                </Grid.ColumnDefinitions>

                <!-- 1. Пошук -->
                <TextBox Grid.Column="0" Padding="12,10" Background="#F4F7FE" BorderThickness="0" VerticalContentAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <!-- 2. Комбобокс -->
                <ComboBox Grid.Column="1" Width="140" Margin="15,0,0,0" Padding="10" Background="#F4F7FE" BorderThickness="0" SelectedIndex="0" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Всі класи ТЗ"/>
                </ComboBox>

                <!-- 3. Чекбокс -->
                <CheckBox Grid.Column="2" Content="Тільки доступні" VerticalAlignment="Center" Margin="20,0"/>

                <!-- 4. Сортування -->
                <Button Grid.Column="3" Content="⇅ Сортувати" Background="#F4F7FE" Foreground="#2B3674" BorderThickness="0" Padding="15,5" Margin="5,0,10,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- 5. Кнопка Додати ТЗ -->
                <Button Grid.Column="4" Content="+ Додати ТЗ" Background="#4318FF" Foreground="White" FontWeight="Bold" Padding="25,12" BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- 4. СПИСОК КАРТОК АВТОМОБІЛІВ -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icVehicles">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="320" Background="White" CornerRadius="20" Margin="10" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.03"/>
                            </Border.Effect>
                            <StackPanel>
                                <!-- Header: Type & Status -->
                                <Grid Margin="0,0,0,15">
                                    <Border Background="#F4F7FE" HorizontalAlignment="Left" Padding="10,4" CornerRadius="6">
                                        <TextBlock Text="{Binding VehicleType}" FontSize="10" FontWeight="Bold" Foreground="#A3AED0"/>
                                    </Border>
                                    <Border Background="#E6FAF5" HorizontalAlignment="Right" Padding="10,4" CornerRadius="6">
                                        <TextBlock Text="ДОСТУПНИЙ" FontSize="10" FontWeight="Bold" Foreground="#05CD99"/>
                                    </Border>
                                </Grid>

                                <!-- Model & Plate -->
                                <TextBlock Text="{Binding Model}" FontSize="20" FontWeight="Bold" Foreground="#2B3674"/>
                                <TextBlock Text="{Binding PlateNumber}" FontSize="14" Foreground="#A3AED0" Margin="0,2,0,15"/>

                                <Separator Background="#F4F7FE" Margin="0,0,0,15"/>

                                <!-- Specs Grid -->
                                <UniformGrid Columns="2" Margin="0,0,0,15">
                                    <StackPanel>
                                        <TextBlock Text="Витрата:" FontSize="11" Foreground="#A3AED0"/>
                                        <TextBlock Text="{Binding FuelConsumption, StringFormat={}{0}L / 100km}" FontWeight="Bold" Foreground="#2B3674"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Амортизація:" FontSize="11" Foreground="#A3AED0" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding AmortizationPerKm, StringFormat={}{0} UAH/km}" FontWeight="Bold" Foreground="#2B3674" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </UniformGrid>

                                <!-- Capacity Info -->
                                <TextBlock Text="Поліморфна ємність:" FontSize="11" Foreground="#A3AED0"/>
                                <TextBlock Text="{Binding CapacityInfo}" FontWeight="Bold" Foreground="#4318FF" Margin="0,2,0,15"/>

                                <Separator Background="#F4F7FE" Margin="0,0,0,15"/>

                                <!-- Bottom Info -->
                                <TextBlock Text="Собівартість км:" FontSize="11" Foreground="#A3AED0"/>
                                <TextBlock Text="{Binding CostPerKm, StringFormat={}{0:N0} UAH/km}" FontSize="18" FontWeight="Bold" Foreground="#2B3674"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>