<Window x:Class="CarFleetApp.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Title="Система керування автопарком " Height="600" Width="900" 
WindowStartupLocation="CenterScreen" Background="#F0F2F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Панель управління автопарком" FontSize="24" FontWeight="Bold" Margin="10,0,10,20" Foreground="#2C3E50"/>

        <TabControl Grid.Row="1" Background="White" BorderBrush="#DCDDE1">

            <!-- Вкладка АВТОПАРК -->
            <TabItem Header="Автопарк">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Сортувати за вартістю" Width="160" Margin="5" Click="SortVehicles_Click" Background="#3498DB" Foreground="White" BorderThickness="0"/>
                        <Button Content="Лише доступні" Width="120" Margin="5" Click="ShowAvailable_Click" Background="#2ECC71" Foreground="White" BorderThickness="0"/>
                        <Button Content="Показати всіх" Width="120" Margin="5" Click="ShowAllVehicles_Click" Background="#95A5A6" Foreground="White" BorderThickness="0"/>
                    </StackPanel>

                    <DataGrid x:Name="dgVehicles" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="*"/>
                            <DataGridTextColumn Header="Номер" Binding="{Binding PlateNumber}" Width="100"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding VehicleType}" Width="150"/>
                            <DataGridTextColumn Header="Витрата (л/100км)" Binding="{Binding FuelConsumption}" Width="120"/>
                            <DataGridTextColumn Header="Ціна оренди/км" Binding="{Binding RentalPricePerKm, StringFormat={}{0} грн}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Доступна" Binding="{Binding IsAvailable}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка ПОЇЗДКИ -->
            <TabItem Header="Поїздки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Створити нову поїздку" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="➕ Симулювати поїздку" Click="AddTrip_Click" Margin="10,5" Background="#E67E22" Foreground="White" BorderThickness="0"/>
                            <TextBlock Text="*Для спрощення додається випадкова поїздка" VerticalAlignment="Center" Margin="10,0,0,0" FontStyle="Italic" Foreground="Gray"/>
                        </StackPanel>
                    </GroupBox>

                    <DataGrid x:Name="dgTrips" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=\{0:dd.MM HH:mm\}}" Width="100"/>
                            <DataGridTextColumn Header="Авто" Binding="{Binding Vehicle.Model}" Width="*"/>
                            <DataGridTextColumn Header="Дистанція" Binding="{Binding Distance, StringFormat={}{0} км}" Width="80"/>
                            <DataGridTextColumn Header="Дохід" Binding="{Binding ClientPayment, StringFormat={}{0} грн}" Width="100"/>
                            <DataGridTextColumn Header="Витрати" Binding="{Binding CurrentExpenses, StringFormat={}{0} грн}" Width="100"/>
                            <DataGridTextColumn Header="Прибуток" Binding="{Binding NetProfit, StringFormat={}{0} грн}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка ЗВІТИ -->
            <TabItem Header="Фінанси">
                <StackPanel Margin="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="10" Padding="40" Background="#F8F9FA">
                        <StackPanel Width="400">
                            <TextBlock Text="Фінансовий звіт компанії" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                            <Grid Margin="0,5">
                                <TextBlock Text="Загальний дохід (оборот):" FontSize="16"/>
                                <TextBlock x:Name="txtTotalIncome" Text="0 грн" FontSize="16" HorizontalAlignment="Right" Foreground="#2980B9" FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,5">
                                <TextBlock Text="Поточні витрати:" FontSize="16"/>
                                <TextBlock x:Name="txtTotalExpenses" Text="0 грн" FontSize="16" HorizontalAlignment="Right" Foreground="#C0392B" FontWeight="Bold"/>
                            </Grid>
                            <Separator Margin="0,15"/>
                            <Grid Margin="0,5">
                                <TextBlock Text="Чистий прибуток:" FontSize="20" FontWeight="Bold"/>
                                <TextBlock x:Name="txtTotalProfit" Text="0 грн" FontSize="20" HorizontalAlignment="Right" Foreground="#27AE60" FontWeight="Bold"/>
                            </Grid>

                            <Button Content="Оновити дані" Margin="0,30,0,0" Padding="10" Click="UpdateReport_Click" Background="#2C3E50" Foreground="White" BorderThickness="0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
